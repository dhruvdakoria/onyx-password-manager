# Onyx Password Manager — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Clerk Auth ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
CLERK_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# ── Resend Emails ────────────────────────────────────────────────────────────
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_REPLACE_WITH_RESEND_KEY
RESEND_FROM_EMAIL=onyx@resend.dev

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
